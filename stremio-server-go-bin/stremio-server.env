# stremio-server-go environment configuration
# Full reference: https://github.com/M0Rf30/stremio-server-go#environment
#
# Every key below is shown at its built-in default and commented out, so the
# package behaves exactly like the bare binary until you uncomment a line.
# This file is read by the systemd unit; a per-user override may be placed at
# ~/.config/stremio-server/env (takes precedence over this file).

# --- Network / ports ---
#HTTP_PORT=11470
#HTTPS_PORT=12470
#BT_LISTEN_PORT=0
#WEB_UI_LOCATION=https://web.stremio.com/

# --- Storage / cache ---
#APP_PATH=%h/.stremio-server
#STREMIO_MEMORY_CACHE_SIZE=0
#STREMIO_MEM_LIMIT=

# --- Local files add-on ---
#LOCAL_FILES_DIR=
#STREMIO_LOCAL_IMDB=on

# --- Transcoding ---
#STREMIO_HWACCEL=

# --- Logging ---
#STREMIO_LOG_LEVEL=info
#STREMIO_LOG_FORMAT=text
#STREMIO_HTTP_LOG=

# --- Stream proxy (/proxy) ---
#STREMIO_PROXY_PASSWORD=
#STREMIO_PROXY_SECRET=
#STREMIO_PROXY_IP_ACL=
#STREMIO_PROXY_PREBUFFER=3
#STREMIO_PROXY_SEG_CACHE_TTL=300
#STREMIO_PROXY_PUBLIC_URL=
#STREMIO_PROXY_UPSTREAM=

# --- Indexer add-ons ---
#STREMIO_BITMAGNET_URL=
#STREMIO_TORZNAB_URL=
#STREMIO_TORZNAB_APIKEY=
#STREMIO_METADATA_URL=https://v3-cinemeta.strem.io

# --- Casting ---
#STREMIO_ENABLE_DLNA=

# --- HTTPS cert provisioning ---
#STREMIO_CERT_AUTHKEY=
#STREMIO_CERT_IP=

# --- BitTorrent engine ---
#STREMIO_PEERS_PER_TORRENT=50
#STREMIO_DISABLE_WEBTORRENT=on
#STREMIO_DISABLE_TRACKERS=
#STREMIO_TRACKERS_URL=

# --- Censorship resistance (see README "Censorship resistance") ---
#STREMIO_BT_ENCRYPTION=prefer
#STREMIO_BT_PROXY=
#STREMIO_DHT_BOOTSTRAP=
#STREMIO_BT_ANONYMOUS=
