# Maintainer: robertfoster

pkgname=yap-bin
pkgver=2.4.1 # renovate: datasource=github-releases depName=M0Rf30/yap
pkgrel=1
pkgdesc="Package software with ease"
arch=('x86_64' 'aarch64')
url="https://github.com/M0Rf30/yap"
license=('GPL-3.0-only')
depends=('glibc')
optdepends=(
  'apk-tools: for alpine experimenting on native host'
  'pacman: for arch experimenting on native host'
)
provides=("${pkgname%-bin}")
conflicts=("${pkgname%-bin}")
options=('!strip')

source_x86_64=("${pkgname%-bin}-${pkgver}-x86_64.tar.gz::${url}/releases/download/v${pkgver}/yap_Linux_x86_64.tar.gz")
source_aarch64=("${pkgname%-bin}-${pkgver}-aarch64.tar.gz::${url}/releases/download/v${pkgver}/yap_Linux_arm64.tar.gz")

sha256sums_x86_64=('e1d7edbf99cfa2660ace87b6b5384445395d2813dbf88cad24c1f7dc48dcb25e')
sha256sums_aarch64=('3740542c355ea5ab4dab4e8c2ccbaade7173740a1a02fe5e808622d2133a4497')

package() {
  install -Dm755 "${srcdir}/${pkgname%-bin}" \
    "${pkgdir}/usr/bin/${pkgname%-bin}"

  mkdir -p "${pkgdir}/usr/share/bash-completion/completions/"
  mkdir -p "${pkgdir}/usr/share/zsh/site-functions/"
  mkdir -p "${pkgdir}/usr/share/fish/vendor_completions.d/"

  "${srcdir}/${pkgname%-bin}" completion bash > \
    "${pkgdir}/usr/share/bash-completion/completions/${pkgname%-bin}"
  "${srcdir}/${pkgname%-bin}" completion zsh > \
    "${pkgdir}/usr/share/zsh/site-functions/_${pkgname%-bin}"
  "${srcdir}/${pkgname%-bin}" completion fish > \
    "${pkgdir}/usr/share/fish/vendor_completions.d/${pkgname%-bin}.fish"

  install -Dm644 -t \
    "${pkgdir}/usr/share/licenses/${pkgname%-bin}" "${srcdir}/LICENSE.md"
  install -Dm644 -t \
    "${pkgdir}/usr/share/doc/${pkgname%-bin}" "${srcdir}/README.md"
}
