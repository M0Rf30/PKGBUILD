# MediaFlow Proxy Light environment configuration
# See: https://github.com/mhdzumair/mediaflow-proxy-light#configuration

# --- Server ---
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8888
#APP__SERVER__WORKERS=4

# --- Auth (REQUIRED) ---
# The proxy will refuse to authenticate requests until this is set.
APP__AUTH__API_PASSWORD=changeme

# --- Logging ---
APP__LOG_LEVEL=info

# --- Optional: load a TOML config file instead of / in addition to env vars ---
#CONFIG_PATH=/etc/mediaflow-proxy-light/config.toml

# --- Proxy / routing (defaults shown) ---
#APP__PROXY__CONNECT_TIMEOUT=30
#APP__PROXY__BUFFER_SIZE=262144
#APP__PROXY__FOLLOW_REDIRECTS=true
#APP__PROXY__PROXY_URL=socks5://user:pass@proxy:1080
#APP__PROXY__ALL_PROXY=false

# --- HLS / MPD / DRM / EPG ---
#APP__HLS__PREBUFFER_SEGMENTS=5
#APP__HLS__SEGMENT_CACHE_TTL=300
#APP__MPD__LIVE_PLAYLIST_DEPTH=8
#APP__DRM__KEY_CACHE_TTL=3600
#APP__EPG__CACHE_TTL=3600

# --- Redis (optional) ---
#APP__REDIS__URL=redis://localhost:6379
#APP__REDIS__CACHE_NAMESPACE=mfpl
